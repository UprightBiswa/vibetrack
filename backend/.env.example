APP_ENV=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=VibeTrack API
APP_AUTO_CREATE_TABLES=true

# Neon / Postgres.
# Use the async SQLAlchemy driver form:
# postgresql+asyncpg://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
DATABASE_URL=

# Supabase is currently used for Auth. The backend verifies Supabase access tokens.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=

# Comma-separated admin email allow-list.
SUPERADMIN_EMAILS=

# Optional for later cache/job/live-session work.
REDIS_URL=redis://localhost:6379/0

# Firebase Admin credentials for push notifications.
# Prefer GOOGLE_APPLICATION_CREDENTIALS locally.
GOOGLE_APPLICATION_CREDENTIALS=backend/secrets/firebase-service-account.json
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
